# LLM Provider: "ollama", "openai", or "pattern" (no LLM, fastest)
LLM_PROVIDER=openai

# Ollama settings (if using local Ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# OpenAI-compatible settings
# For Groq (free, fast): get key at https://console.groq.com
OPENAI_API_KEY=your-groq-api-key-here
OPENAI_MODEL=llama-3.3-70b-versatile
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_API_COMPAT=standard

# For llama.cpp (internal server): uncomment below
# OPENAI_API_KEY=not-needed
# OPENAI_MODEL=mistral
# OPENAI_BASE_URL=https://your-server:port/v1
# OPENAI_API_COMPAT=llamacpp

# App settings
MAX_FILE_SIZE_MB=50
SUPPORTED_EXTENSIONS=.py,.js,.ts,.java,.go,.rb
